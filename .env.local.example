# Firebase (client) — z konsoli Firebase, sekcja "Project settings" > "Your apps"
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (seed/server) — z service account JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Anthropic — nigdy nie wystawiaj na klienta
ANTHROPIC_API_KEY=

# Mostek XP do Projektu 30 (server-side) — wymagane przez /api/projekt30-xp,
# bez nich route zwraca 500. Shared secret = LEARNING_VAULT_API_KEY w P30.
PROJEKT30_API_URL=https://projekt-30.vercel.app/api/external/xp
PROJEKT30_API_KEY=

# Domyślny userId do seeda (Firebase Auth UID Natalii)
SEED_USER_ID=

# Allowlist UID-ów dla /api/generate, /api/grade, /api/salon-feedback,
# /api/projekt30-xp — CSV, zwykle ten sam UID co SEED_USER_ID.
# Wymaga skonfigurowanych FIREBASE_PROJECT_ID/CLIENT_EMAIL/PRIVATE_KEY.
ALLOWED_UIDS=
